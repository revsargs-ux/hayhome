    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "qrcode.react": "^4.2.0",
