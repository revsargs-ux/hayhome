# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-256-bit-secret

# ── AI (ZAI / GLM-5.2) ────────────────────────────────────────────────────────
AI_API_KEY=your-key-from-z.ai
AI_BASE_URL=https://api.z.ai/api/paas/v4
AI_MODEL=glm-5.2

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
YOOKASSA_CLIENT_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
YOOKASSA_WEBHOOK_SECRET=your-webhook-shared-secret

# ── OAuth (необязательно) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://hay-home.com
